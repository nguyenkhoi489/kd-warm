<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Privileged helper runs unsandboxed as a daemon. Hardened Runtime base;
	     real client-signature requirements wired with SMAppService in Phase 4. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>

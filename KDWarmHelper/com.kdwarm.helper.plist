<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- SMAppService daemon plist. Embedded in the app at Contents/Library/LaunchDaemons/ and
     registered via SMAppService.daemon(plistName:). The helper executable ships in Contents/MacOS.
     Live registration is gated on Developer ID signing (Phase 9); the layout is in place now. -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kdwarm.helper</string>
    <key>BundleProgram</key>
    <string>Contents/MacOS/KDWarmHelper</string>
    <key>MachServices</key>
    <dict>
        <key>com.kdwarm.helper</key>
        <true/>
    </dict>
    <key>AssociatedBundleIdentifiers</key>
    <array>
        <string>com.kdwarm.app</string>
    </array>
</dict>
</plist>

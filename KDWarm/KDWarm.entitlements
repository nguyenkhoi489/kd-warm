<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Non-sandboxed (DMG distribution). Hardened Runtime base — JIT / network
	     entitlements added in Phase 9 when bundled runtimes need them. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
